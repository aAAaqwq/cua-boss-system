# DeepSeek API 配置 — 用于 BOSS直聘智能回复
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

DEEPSEEK_API_KEY=sk-your-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ── 云同步（Supabase）配置 —— 见 docs/cloud-sync-plan.md / supabase/schema.sql ──
# 总开关：on 才会在采集/评分后自动上云；off(默认) 完全不碰云。
CLOUD_SYNC=off
# Supabase 项目地址（建好项目后填；区域随意，迁移只改这行）
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key（agent 上传用，绕过 RLS）——绝密，绝不进前端/git
SUPABASE_KEY=your-service-role-key
# 本机数据归属的租户 = 你的 Supabase 用户 auth uid（uuid）
TENANT_ID=your-auth-user-uuid
# 目标表名（默认 candidates，一般不用改）
# CLOUD_TABLE=candidates
