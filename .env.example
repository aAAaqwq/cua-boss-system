# DeepSeek API 配置 — 用于 BOSS直聘智能回复
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

DEEPSEEK_API_KEY=sk-your-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ── 云同步（Supabase）—— 见 docs/数据安全说明.md / docs/cloud-sync-plan.md ──
# 总开关：on 才会在采集/沟通后自动上云；off(默认) 完全不碰云。
CLOUD_SYNC=off
# Supabase 项目地址
SUPABASE_URL=https://your-project-ref.supabase.co
# anon key（公开安全，受 RLS 约束）——登录 + 上传都用它
SUPABASE_ANON_KEY=your-anon-key
# 目标表名（默认 candidates，一般不用改）
# CLOUD_TABLE=candidates
#
# 【推荐·多用户】登录绑定账号后才能上云（账号由服务端创建/下发）：
#   python scripts/cloud_sync.py login --email 你的邮箱 --password 你的密码
#   登录态存 data/.cloud_auth.json，上云以该账号身份、RLS 只能写自己数据。
#
# 【可选·仅拥有者】service_role 绕过 RLS（权限极大，绝不发给普通用户/前端/git）：
# SUPABASE_KEY=your-service-role-key
# TENANT_ID=your-auth-user-uuid
