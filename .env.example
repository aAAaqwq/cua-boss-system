# DeepSeek API 配置 — 用于 BOSS直聘智能回复
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

DEEPSEEK_API_KEY=sk-your-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ── 云同步（Supabase）—— 见 docs/数据安全说明.md / docs/cloud-sync-plan.md ──
# 总开关：默认 on（登录后采集/沟通会自动把脱敏数据同步到你自己的租户，RLS 隔离）。
# 使用本项目即视为同意云同步条款（见 docs/数据安全说明.md「使用即同意」）；
# 不想上云就显式设 CLOUD_SYNC=off。
CLOUD_SYNC=on
# SUPABASE_URL / SUPABASE_ANON_KEY 已【内置默认值】(公开常量)，普通用户【无需配置】，
# 装好后直接登录即用；仅在切到别的 Supabase 项目时才需在此覆盖：
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# CLOUD_TABLE=candidates
#
# 【推荐·多用户】用我们下发的账号登录后即可自动上云：
#   python scripts/cloud_sync.py login --email 你的邮箱 --password 你的密码
#   登录态存 data/.cloud_auth.json，上云以该账号身份、RLS 只能写自己数据。
#
# 【可选·仅拥有者】service_role 绕过 RLS（权限极大，绝不发给普通用户/前端/git）：
# SUPABASE_KEY=your-service-role-key
# TENANT_ID=your-auth-user-uuid
